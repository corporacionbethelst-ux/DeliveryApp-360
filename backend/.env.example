# ============================================
# DELIVERY360 - VARIABLES DE ENTORNO
# ============================================
# Copiar este archivo como .env y ajustar los valores
# ============================================

# ============================================
# CONFIGURACIÓN GENERAL DE LA APLICACIÓN
# ============================================
APP_NAME=Delivery360
APP_VERSION=1.2.3
APP_ENV=development
ENVIRONMENT=development
DEBUG=False
SECRET_KEY=DVb1Bx3McB2IkOCcnLjGJfEcuVzbOYvVDMdbr8kEt1E

# URL del Frontend para enlaces de recuperación y redirecciones
FRONTEND_URL=http://localhost:3000

# ============================================
# CONFIGURACIÓN DE LA BASE DE DATOS POSTGRESQL
# ============================================
POSTGRES_DB=delivery360
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# URL completa para conexión asíncrona (usar si no se usan las variables individuales)
DATABASE_URL=postgresql://admin:admin123@db:5432/delivery360

# URL completa para conexión síncrona (requerida para Alembic migrations)
DATABASE_URL_SYNC=postgresql://admin:admin123@db:5432/delivery360

# ============================================
# CONFIGURACIÓN DE REDIS
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# CONFIGURACIÓN DE JWT PARA AUTENTICACIÓN
# ============================================
ALGORITHM=HS256
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# CONFIGURACIÓN DE CELERY PARA TAREAS EN BACKGROUND
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================
# CONFIGURACIÓN DE CORS PARA EL FRONTEND
# ============================================
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ============================================
# CONFIGURACIÓN DE LGPD Y RETENCIÓN DE DATOS
# ============================================
LGPD_RETENTION_DAYS=1825
DATA_RETENTION_DAYS=90

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_PER_MINUTE=60

# ============================================
# CONFIGURACIÓN DEL PRIMER SUPERUSUARIO (SEED)
# ============================================
FIRST_SUPERUSER_EMAIL=admin@delivery360.com
FIRST_SUPERUSER_PASSWORD=admin123
FIRST_SUPERUSER_NAME=Administrador

# ============================================
# MONITOREO Y LOGGING
# ============================================
LOG_LEVEL=INFO
SENTRY_DSN=

# ============================================
# SERVICIOS EXTERNOS OPCIONALES
# ============================================
# Google Maps API para geocodificación y mapas
GOOGLE_MAPS_API_KEY=

# Mapbox API (alternativa a Google Maps)
MAPBOX_API_KEY=

# ============================================
# CONFIGURACIÓN DE EMAIL (SMTP)
# ============================================
EMAILS_ENABLED=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion
EMAIL_FROM=noreply@delivery360.com
# Nombre que aparecerá en los correos enviados (opcional, usa APP_NAME si no se define)
MAIL_FROM_NAME=Delivery360

# ============================================
# ALMACENAMIENTO DE ARCHIVOS (S3 Compatible)
# ============================================
AWS_S3_BUCKET=delivery360-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_ENDPOINT_URL=

# ============================================
# NOTIFICACIONES PUSH (Firebase)
# ============================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================
# INTEGRACIONES EXTERNAS
# ============================================
# iFood / UberEats / Rappi API Keys
IFOOD_API_KEY=
UBEREATS_API_KEY=
RAPPI_API_KEY=

# ERP Integrations (SAP, Oracle, Totvs)
ERP_API_URL=
ERP_API_KEY=

# ============================================
# PAGOS (Stripe, MercadoPago, Pagar.me)
# ============================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
MERCADOPAGO_ACCESS_TOKEN=
PAGARME_API_KEY=
