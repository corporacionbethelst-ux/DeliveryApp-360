# ==========================================
# DELIVERY360 - VARIABLES DE AMBIENTE
# ==========================================
# Copiar este archivo como .env y ajustar los valores
# NUNCA subir el archivo .env real al repositorio
# ==========================================

# ------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS
# ------------------------------------------
DATABASE_URL=postgresql://admin:admin123@db:5432/delivery360
DATABASE_URL_SYNC=postgresql+asyncpg://admin:admin123@db:5432/delivery360

# Para producción usar credenciales seguras:
# DATABASE_URL=postgresql://user:STRONG_PASSWORD@host:5432/delivery360

# ------------------------------------------
# REDIS (Cola de tareas y caché)
# ------------------------------------------
REDIS_URL=redis://redis:6379

# Para producción con autenticación:
# REDIS_URL=redis://:STRONG_PASSWORD@redis-host:6379

# ------------------------------------------
# SEGURIDAD - CRÍTICO PARA PRODUCCIÓN
# ------------------------------------------
# Generar una nueva clave para cada entorno:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=DVb1Bx3McB2IkOCcnLjGJfEcuVzbOYvVDMdbr8kEt1E

# Tiempo de expiración de tokens (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Entorno (development, staging, production)
ENVIRONMENT=development

# Nombre del proyecto
PROJECT_NAME=Delivery360

# ------------------------------------------
# FRONTEND
# ------------------------------------------
FRONTEND_URL=http://localhost:3000

# Para producción:
# FRONTEND_URL=https://app.delivery360.com

# URL de la API para el frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Para producción:
# NEXT_PUBLIC_API_URL=https://api.delivery360.com/api/v1

# Proveedor de mapas (leaflet, google, mapbox)
NEXT_PUBLIC_MAPS_PROVIDER=leaflet

# Keys de servicios de mapas (si se usan)
# GOOGLE_MAPS_API_KEY=tu_api_key_aqui
# MAPBOX_ACCESS_TOKEN=tu_token_aqui

# ------------------------------------------
# CONFIGURACIÓN DE EMAIL (SMTP)
# ------------------------------------------
EMAILS_ENABLED=True
SMTP_HOST smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_SSL=False

# Credenciales SMTP - USAR APP PASSWORD en Gmail
SMTP_USER=tu_email@empresa.com
SMTP_PASSWORD=tu_password_de_aplicacion

# Email remitente
EMAIL_FROM=noreply@delivery360.com
EMAIL_FROM_NAME=Delivery360

# Para producción usar servicio profesional:
# SendGrid, Mailgun, AWS SES, etc.

# ------------------------------------------
# ALMACENAMIENTO DE ARCHIVOS
# ------------------------------------------
# Directorio local para uploads (desarrollo)
UPLOAD_DIR=/app/uploads

# Para producción usar S3 o similar:
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_STORAGE_BUCKET_NAME=delivery360-uploads
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=https://cdn.delivery360.com

# ------------------------------------------
# CELERY (Worker de tareas asíncronas)
# ------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ------------------------------------------
# MONITOREO Y LOGGING
# ------------------------------------------
# Sentry para tracking de errores
SENTRY_DSN=
# https://your-project@sentry.io/123456

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ------------------------------------------
# RATE LIMITING
# ------------------------------------------
# Límite de requests por minuto por IP
RATE_LIMIT_PER_MINUTE=60

# Límite de intentos de login fallidos
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ------------------------------------------
# Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Para producción:
# CORS_ORIGINS=https://app.delivery360.com,https://admin.delivery360.com

# ------------------------------------------
# SLA Y TIEMPOS DE ENTREGA
# ------------------------------------------
# Tiempo máximo estándar de entrega (minutos)
DEFAULT_SLA_MINUTES=60

# Tiempo máximo para entregas urgentes
URGENT_SLA_MINUTES=30

# Radio máximo de cobertura (km)
MAX_DELIVERY_RADIUS_KM=10

# ------------------------------------------
# PAGOS Y COMISIONES
# ------------------------------------------
# Comisión de la plataforma (% sobre delivery fee)
PLATFORM_COMMISSION_PERCENT=20

# Pago mínimo por entrega
MIN_DELIVERY_PAYMENT=3000

# Pago por km recorrido
PAYMENT_PER_KM=500

# ------------------------------------------
# GEOLocalización
# ------------------------------------------
# Distancia máxima para considerar check-in válido (metros)
CHECKIN_MAX_DISTANCE_METERS=100

# Frecuencia de actualización de tracking (segundos)
TRACKING_UPDATE_INTERVAL_SECONDS=30

# ------------------------------------------
# NOTIFICACIONES PUSH (Opcional)
# ------------------------------------------
# Firebase Cloud Messaging
# FCM_SERVER_KEY=tu_server_key
# FCM_SENDER_ID=tu_sender_id

# OneSignal (alternativa)
# ONESIGNAL_APP_ID=tu_app_id
# ONESIGNAL_REST_KEY=tu_rest_key

# ------------------------------------------
# INTEGRACIONES EXTERNAS
# ------------------------------------------
# Webhook URL para notificaciones externas
WEBHOOK_SECRET=tu_webhook_secret

# API keys para integraciones con POS/ERP
# POS_API_KEY=tu_pos_api_key
# ERP_API_KEY=tu_erp_api_key

# ------------------------------------------
# BACKUP Y RECUPERACIÓN
# ------------------------------------------
# Ruta para backups automáticos (solo desarrollo)
BACKUP_DIR=/app/backups

# Para producción usar S3/GCS con versionamiento
# BACKUP_BUCKET=delivery360-backups
# BACKUP_RETENTION_DAYS=30

# ------------------------------------------
# VARIABLES ESPECÍFICAS DE ENTORNO
# ------------------------------------------

# Desarrollo
# DEBUG=True
# ALLOW_SELF_SIGNED_CERTS=True

# Producción
DEBUG=False
ALLOW_SELF_SIGNED_CERTS=False
SECURE_COOKIES=True
SESSION_COOKIE_SECURE=True
